# .env.production.example - Plantilla de variables para endurecimiento estricto en producción.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_PORTAL_SLUG=

UPSTASH_REDIS_REST_URL=https://your-upstash-production-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-production-token

SECURITY_RATE_LIMIT_DISTRIBUTED_TIMEOUT_MS=800

AUTH_RATE_LIMIT_REQUIRE_DISTRIBUTED=true
AUTH_RATE_LIMIT_FAIL_CLOSED=true

ADMIN_RATE_LIMIT_REQUIRE_DISTRIBUTED=true
ADMIN_RATE_LIMIT_FAIL_CLOSED=true
