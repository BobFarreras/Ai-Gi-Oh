# .env.example - Variables mínimas requeridas para autenticación con Supabase en entornos locales.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo servidor: necesario para escrituras admin controladas en /api/admin/*
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_PORTAL_SLUG=

# Rate limiting distribuido opcional (Upstash Redis REST).
# Si no se define, se aplica fallback local en memoria.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Timeout de peticiones al backend distribuido de rate limit (ms, rango efectivo 200-5000).
SECURITY_RATE_LIMIT_DISTRIBUTED_TIMEOUT_MS=1200

# Modo estricto recomendado para staging/prod en auth.
# true: si falta backend distribuido, bloquea peticiones.
AUTH_RATE_LIMIT_REQUIRE_DISTRIBUTED=false
# true: si el backend distribuido falla en runtime, bloquea peticiones (fail-closed).
AUTH_RATE_LIMIT_FAIL_CLOSED=false

# Modo estricto recomendado para staging/prod en mutaciones admin.
ADMIN_RATE_LIMIT_REQUIRE_DISTRIBUTED=false
ADMIN_RATE_LIMIT_FAIL_CLOSED=false

# Modo estricto recomendado para staging/prod en mutaciones de perfil de jugador.
PLAYER_PROFILE_RATE_LIMIT_REQUIRE_DISTRIBUTED=false
PLAYER_PROFILE_RATE_LIMIT_FAIL_CLOSED=false

# Perf E2E real (opcional).
PERF_EMAIL=
PERF_PASSWORD=
PERF_BASE_URL=http://localhost:3000
PERF_COMBAT_PATH=

# Seguridad adicional en producción para tickets de cierre de duelo.
# Fallback automático:
# - Producción: usa SUPABASE_SERVICE_ROLE_KEY si esta variable está vacía.
# - Desarrollo: usa secreto dev interno si ambas variables están vacías.
DUEL_COMPLETION_TOKEN_SECRET=

# Recompensa final del tutorial (opcional; default interno si vacío).
TUTORIAL_FINAL_REWARD_NEXUS=
