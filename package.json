{
  "name": "ai-gi-oh",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "quality:check": "pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm build",
    "perf:baseline:mobile": "node scripts/performance/run-mobile-baseline.mjs",
    "perf:baseline:mobile:realistic": "node scripts/performance/run-mobile-baseline.mjs --profile=realistic",
    "perf:baseline:mobile:stress": "node scripts/performance/run-mobile-baseline.mjs --profile=stress",
    "perf:baseline:mobile:auto": "node scripts/performance/run-mobile-baseline.mjs --profile=both --startServer=\"pnpm dev\"",
    "perf:baseline:mobile:auto:prod": "node scripts/performance/run-mobile-baseline.mjs --profile=both --startServer=\"pnpm start\"",
    "perf:combat:e2e": "node scripts/performance/run-combat-e2e.mjs",
    "perf:combat:e2e:auto:dev": "node scripts/performance/run-combat-e2e.mjs --startServer=\"pnpm dev\"",
    "perf:combat:e2e:auto:prod": "node scripts/performance/run-combat-e2e.mjs --startServer=\"pnpm start\"",
    "perf:combat:e2e:real": "node scripts/performance/run-combat-e2e-real.mjs",
    "perf:combat:e2e:real:auto:dev": "node scripts/performance/run-combat-e2e-real.mjs --startServer=\"pnpm dev\"",
    "perf:combat:e2e:real:auto:prod": "node scripts/performance/run-combat-e2e-real.mjs --startServer=\"pnpm start\"",
    "perf:combat:e2e:real:stress:auto:prod": "node scripts/performance/run-combat-e2e-real.mjs --profile=stress --startServer=\"pnpm start\""
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "playwright": "^1.54.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
