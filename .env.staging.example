# .env.staging.example - Plantilla de variables para endurecimiento progresivo en entorno staging.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_PORTAL_SLUG=

UPSTASH_REDIS_REST_URL=https://your-upstash-staging-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-staging-token

SECURITY_RATE_LIMIT_DISTRIBUTED_TIMEOUT_MS=900

AUTH_RATE_LIMIT_REQUIRE_DISTRIBUTED=true
AUTH_RATE_LIMIT_FAIL_CLOSED=false

ADMIN_RATE_LIMIT_REQUIRE_DISTRIBUTED=true
ADMIN_RATE_LIMIT_FAIL_CLOSED=true
